# Required: AI provider key for the chat sidebar
OPENROUTER_API_KEY=

# Optional: override default model (default: openai/gpt-oss-120b)
# OPENROUTER_MODEL=

# Optional: override demo login credentials
# DEMO_USERNAME=user
# DEMO_PASSWORD=password

# Optional: set to "production" to enable secure cookies (requires HTTPS)
# ENVIRONMENT=production

# Optional: CORS allowed origin for the frontend (default: http://localhost:3000)
# FRONTEND_URL=http://localhost:3000

# Optional: override SQLite database path
# PM_DB_PATH=/data/db.sqlite3
